    "# ─────────────────────────────────────────────\n",
    "# 9.3 HEATMAP — FEATURES NUMÉRICAS POR DÉCADA\n",
    "# ─────────────────────────────────────────────\n",
    "df_heatmap = pd.DataFrame(\n",
