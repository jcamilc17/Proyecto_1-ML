     ]
    }
   ],
   "source": [
    "# ── 11.4 Stemming previo ──\n",
    "stemmer = PorterStemmer()\n",
    "\n",
    "def stem_text(text):\n",
    "    tokens = word_tokenize(text.lower())\n",
    "    return ' '.join([stemmer.stem(t) for t in tokens if t.isalnum()])\n",
    "\n",
    "# Aplicar stemming a train, test y eval\n",
    "X_train_stem = X_train.copy()\n",
    "X_test_stem  = X_test.copy()\n",
    "X_eval_stem  = X_eval.copy()\n",
    "\n",
    "X_train_stem['text_clean'] = X_train['text_clean'].apply(stem_text)\n",
    "X_test_stem['text_clean']  = X_test['text_clean'].apply(stem_text)\n",
    "X_eval_stem['text_clean']  = df_eval['text_clean'].apply(stem_text)\n",
    "\n",
    "# Verificar ejemplo\n",
    "print(f\"Original: {X_train['text_clean'].iloc[0][:100]}\")\n",
    "print(f\"Stemming: {X_train_stem['text_clean'].iloc[0][:100]}\")"
   ]
